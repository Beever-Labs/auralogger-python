# AURALOGGER_PROJECT_TOKEN="paste-from-auralogger-init"
# AURALOGGER_USER_SECRET="paste-from-auralogger-init"
#
# Optional (resolved by proj_auth if unset)
# AURALOGGER_PROJECT_SESSION="..."
# AURALOGGER_PROJECT_STYLES='[...]'
#
# Optional overrides (self-hosted / contributors)
# AURALOGGER_API_URL=https://auralogger.com
# AURALOGGER_WS_URL=wss://api.auralogger.com

